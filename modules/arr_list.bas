' ИСПРАВЛЕНИЕ #4: инвертировано условие пропуска строк.
' В оригинале GoTo 22 срабатывал когда c(i,2) <> "" (есть значение = строка-заголовок),
' то есть строки-заголовки НЕ пропускались, а строки с товарами пропускались.
' Остатки записывались в заголовки вместо товаров.
' Теперь: GoTo 22 (пропуск) при c(i,2) = "" или IsEmpty — т.е. при строках с товарами.
' Строки-заголовки (c(i,2) = 1) остатков не получают — корректно.
Private Sub parse_ost()
On Error Resume Next

        Call find_cm_sk

        With ThisWorkbook.Sheets("sk_123")

            r7 = .Cells(Rows.Count, cm).End(xlUp).Row + 3
            ost = .Range(.Cells(2, cm), .Cells(r7, cm)).value

            For i = LBound(c) To UBound(c)

                ' Пропускаем строки-товары (c(i,2) пустое) — остаток им не нужен
                If c(i, 2) = "" Then GoTo 22
                If IsEmpty(c(i, 2)) Then GoTo 22

                ' Строка-заголовок: показываем прочерк
                c(i, 6) = "---------------------------------"

22
                ' Для строк-товаров записываем реальный остаток из листа sk_123
                If c(i, 2) = "" Or IsEmpty(c(i, 2)) Then
                    c(i, 6) = ost(i, 1)
                End If

            Next

        End With

End Sub

